# Server Configuration
PORT=8000
NODE_ENV=production

# CockroachDB Connection String
DATABASE_URL=postgresql://user:password@host:26257/defaultdb?sslmode=verify-full

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# JWT Secret (Generate a strong secret for production)
JWT_SECRET=your_jwt_secret_here

# Web Push Configuration
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=your_email@example.com

# M-Pesa Daraja API (Safaricom)
# Set MPESA_ENV=production to use live Daraja, else sandbox is used
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_daraja_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback
SERVER_URL=https://yourdomain.com

# Africa's Talking (SMS)
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key
AT_SENDER_ID=KBA
